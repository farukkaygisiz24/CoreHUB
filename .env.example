# AI — virgülle zincir (günlük kota dolunca sıradakine geçer)
AI_CHAIN=groq:llama-3.3-70b-versatile,groq:llama-3.1-8b-instant
GROQ_API_KEY=

# Görseller (kaynak yoksa yedek)
UNSPLASH_ACCESS_KEY=

# Vercel Cron + manuel tetikleme koruması (rastgele uzun bir string)
CRON_SECRET=

# Vercel Blob — production'da articles.json burada tutulur
# Vercel Dashboard → Storage → Blob oluştur → token otomatik gelir
BLOB_READ_WRITE_TOKEN=

# Vercel serverless süre sınırına uyum için run başına haber sayısı (varsayılan 12)
INGEST_MAX_PER_RUN=3
