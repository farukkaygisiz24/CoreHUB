# AI — virgülle zincir (günlük kota dolunca sıradakine geçer)
AI_CHAIN=groq:llama-3.3-70b-versatile,groq:llama-3.1-8b-instant
GROQ_API_KEY=

# Görseller (kaynak yoksa yedek)
UNSPLASH_ACCESS_KEY=

# Vercel Cron + manuel tetikleme koruması (rastgele uzun bir string)
CRON_SECRET=

# Vercel Blob — production'da articles.json burada tutulur
# Vercel Dashboard → Storage → Blob oluştur → token otomatik gelir
BLOB_READ_WRITE_TOKEN=

# Vercel: run başına max haber (normal mod, varsayılan 6)
INGEST_MAX_PER_RUN=6

# Son kaç günün RSS haberleri alınsın (publishedAt / isoDate ile)
INGEST_MAX_AGE_DAYS=3

# İlk kurulum: depo bu sayının altındayken backfill (feed başı 30 item, 3 gün pencere)
INGEST_BOOTSTRAP_UNTIL=50
INGEST_BOOTSTRAP_PER_FEED=30
INGEST_BOOTSTRAP_MAX_PER_RUN=6
# Pro plan: backfill hızlandırma için 12 yapılabilir (maxDuration=300s)
